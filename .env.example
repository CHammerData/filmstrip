# Copy to .env and adjust. Real Radarr/Letterboxd config lives in the database
# (Settings / User / List) — the variables below are only for local process config
# and for the one-time `npm run seed` bootstrap until the GUI (M3) exists.

# ---- Process config (always used) ----
# Prisma SQLite database. Path is relative to the prisma/ schema dir => prisma/dev.db
DATABASE_URL="file:./dev.db"
LOG_LEVEL=info            # error | warn | info | debug
NODE_ENV=development      # development | production | test
PORT=3000                 # REST API port (src/index.ts); routes are served under /api

# Run mode:
#   gui       (default) — serves the React SPA + the full auth-gated /api.
#   headless             — no UI/auth; runs the sync scheduler + /api/health only, and (re)seeds
#                          the DB from the seed vars below on every boot (env is the source of
#                          truth). Use this for a GUI-less, upstream-lettarrboxd-style deployment.
# FILMSTRIP_MODE=gui

# ---- Seed-time (read by `npm run seed`, and by headless boot; written into the DB) ----
# Radarr connection + defaults stored on the Settings row:
# RADARR_API_URL=http://localhost:7878
# RADARR_API_KEY=your_radarr_api_key_here
# RADARR_QUALITY_PROFILE=HD-1080p          # must match Radarr exactly (case-sensitive)
# RADARR_MINIMUM_AVAILABILITY=released     # announced | inCinemas | released

# Jellyfin connection (optional; powers watched-state + makeCollection):
# JELLYFIN_URL=http://localhost:8096
# JELLYFIN_API_KEY=your_jellyfin_api_key_here

# The owning user + the list to monitor:
# SEED_USER_NAME=chris
# SEED_USER_TAG=chris                       # Radarr tag for attribution
# SEED_USER_LETTERBOXD_USERNAME=chris       # for Letterboxd watched-state (no @)
# SEED_USER_JELLYFIN_USER_ID=                # Jellyfin user id, for Jellyfin watched-state
# LETTERBOXD_URL=https://letterboxd.com/yourusername/watchlist/
# SEED_LIST_LABEL=My watchlist

# Safety: seed defaults DRY_RUN to true so the first sync makes no Radarr changes.
# DRY_RUN=true
