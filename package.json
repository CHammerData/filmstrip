    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "seed": "ts-node src/db/seed.ts",
    "cli": "ts-node src/cli.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.10.0",
    "bluebird": "^3.7.2",
    "cheerio": "^1.1.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.0",
    "nodemon": "^3.1.10",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/bluebird": "^3.5.42",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.15",
    "@types/supertest": "^7.2.0",
    "express": "^5.1.0",
    "jest": "^30.0.4",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.0"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
