// Lettarrboxd Manager data model.
// SQLite via Prisma. Note: Prisma does not support native enums on SQLite,
// so status/strategy fields are Strings with their allowed values documented inline.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Singleton (id = 1): the Radarr connection + global defaults that Lists fall back to.
model Settings {
  id Int @id @default(1)

  // Radarr connection (single instance for now; could become its own model later)
  radarrUrl    String?
  radarrApiKey String?

  // Jellyfin connection (single instance for now). Powers watched-state + collections.
  jellyfinUrl    String?
  jellyfinApiKey String?

  // Global defaults — a List's null fields inherit these.
  defaultQualityProfile      String?
  defaultRootFolderId        String?
  defaultMinimumAvailability String  @default("released") // announced | inCinemas | released
  defaultCheckIntervalMin    Int     @default(60)
  dryRun                     Boolean @default(false)

  /// How often (minutes) each user's watched-state (diary + aggregate watched-films + Jellyfin)
  /// is refreshed. Global and decoupled from any list's own sync interval -- refreshed once per
  /// user regardless of how many lists they own, not once per list per sync.
  watchedRefreshIntervalMin Int @default(1440) // 24h

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A person whose Letterboxd lists we monitor. Carries a Radarr tag for attribution.
model User {
  id   Int    @id @default(autoincrement())
  name String

  /// Radarr tag applied to everything this user requests (e.g. "chris"). Always
  /// combined with the global "letterboxd" tag and any per-list extraTags.
  tag     String
  enabled Boolean @default(true)

  /// Letterboxd username (no @) -- scraped at /{username}/diary/ + /{username}/films/ for this
  /// user's watched set.
  letterboxdUsername String?
  /// Jellyfin user id -- this user's playback history for the watched set + GUI auth link.
  jellyfinUserId     String? @unique

  /// Last time this user's WatchedFilm rows were refreshed. Drives the decoupled watched-state
  /// scheduler (Settings.watchedRefreshIntervalMin) -- independent of any list's own sync.
  lastWatchedRefreshAt DateTime?

  lists        List[]
  sessions     Session[]
  watchedFilms WatchedFilm[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tag])
}

/// A logged-in GUI session (M6). Created on a successful Jellyfin login; the opaque `token`
/// lives in an httpOnly cookie and is looked up here on each request. Server-side so it can be
/// revoked (logout / admin) before it expires.
model Session {
  id    Int    @id @default(autoincrement())
  token String @unique

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  /// Cached from Jellyfin's Policy.IsAdministrator at login time -- what the middleware checks.
  isAdmin Boolean @default(false)

  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime

  @@index([userId])
}

/// A Letterboxd URL to monitor, owned by a User. Null overrides inherit Settings defaults.
model List {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  url      String
  /// Detected at save time: watchlist | regular_list | watched_movies |
  /// actor_filmography | director_filmography | writer_filmography | collections | popular_movies
  listType String
  label    String
  enabled  Boolean @default(true)

  // Per-list overrides (null => inherit from Settings).
  qualityProfile      String?
  rootFolderId        String?
  minimumAvailability String?
  monitored           Boolean @default(true)
  /// Extra Radarr tags beyond the user tag + "letterboxd" (comma-separated).
  extraTags           String?
  takeAmount          Int?
  takeStrategy        String? // oldest | newest
  checkIntervalMin    Int?
  /// Live, continuous guarantee (DESIGN.md §4-§6): any film this (enabled) list currently claims
  /// is pinned to `kept` immediately, not just when the list is later deleted. Mutually exclusive
  /// with unwatchedOnly/removeOnWatch (enforced in src/server/routes/lists.ts) -- a list that's
  /// meant to keep everything it claims forever can't also be conditioned on watch-state.
  permanence          Boolean @default(false)
  /// Subtract the owner's watched set (Letterboxd ∪ Jellyfin) at scrape time -- skip re-adding them.
  /// Mutually exclusive with permanence.
  unwatchedOnly       Boolean @default(false)
  /// When the owner's Letterboxd diary shows a real watch date after this list started tracking
  /// the film, and no other enabled non-removeOnWatch list still claims it, queue it for deletion
  /// review (doesn't require the film to have left the list -- see DESIGN.md §6-§7). Mutually
  /// exclusive with permanence.
  removeOnWatch       Boolean @default(false)
  /// Maintain a Jellyfin collection (BoxSet) mirroring this list's current films.
  makeCollection         Boolean @default(false)
  collectionNameOverride String?

  lastSyncedAt DateTime?

  syncRuns         SyncRun[]
  listMovies       ListMovie[]
  deletionRequests DeletionRequest[]
  movieEvents      MovieEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, url])
}

/// One row per sync attempt of a List. Powers the GUI history/health view.
model SyncRun {
  id     Int  @id @default(autoincrement())
  list   List @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId Int

  status        String // running | success | partial | failed
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  moviesFound   Int       @default(0)
  moviesAdded   Int       @default(0)
  moviesSkipped Int       @default(0)
  moviesFailed  Int       @default(0)
  dryRun        Boolean   @default(false)
  error         String?

  @@index([listId, startedAt])
}

/// A film, normalized across lists by tmdbId. The anchor for provenance (and, later, pinning).
model Movie {
  id     Int @id @default(autoincrement())
  tmdbId Int @unique

  imdbId String?
  title  String
  year   Int?

  /// The single source of truth for this film's lifecycle (DESIGN.md §10):
  /// wanted | pre_existing | added | deletion_queued | deleted | kept
  /// Written only by transitionMovie (src/movieState.ts) -- never set directly elsewhere.
  /// pre_existing is the provenance keystone: a film Filmstrip didn't itself add to Radarr is
  /// never eligible to move into deletion_queued, even while it sits on a Filmstrip list.
  state String @default("wanted")

  radarrMovieId  Int?
  /// Jellyfin library item id, resolved + cached the first time a makeCollection list needs it.
  jellyfinItemId String?

  listMovies       ListMovie[]
  deletionRequests DeletionRequest[]
  /// Append-only history: every state transition, plus per-list seen/left/restored events that
  /// don't change `state` (e.g. a pre_existing film leaving a list) -- see src/movieState.ts.
  events           MovieEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Append-only per-film history log (DESIGN.md §10). Never updated or deleted, only appended to.
model MovieEvent {
  id      Int   @id @default(autoincrement())
  movie   Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId Int

  /// seen_on_list | left_list | list_deleted | list_deactivated | watch_dropped |
  /// restored_to_list | radarr_add_failed | added_to_radarr | already_in_radarr |
  /// deletion_queued | deletion_queue_cancelled | deleted | kept | revived | backfilled
  type   String
  detail String?

  /// The list involved, when applicable (e.g. seen_on_list/left_list/deletion_queued). Kept on
  /// SetNull so a later list deletion doesn't erase history that already happened.
  list   List? @relation(fields: [listId], references: [id], onDelete: SetNull)
  listId Int?

  createdAt DateTime @default(now())

  @@index([movieId])
}

/// List <-> Movie membership (replaces SyncedMovie): is a film still on this list, and what
/// happened the last time this list tried to add it.
model ListMovie {
  id      Int   @id @default(autoincrement())
  list    List  @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId  Int
  movie   Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId Int

  /// Still present as of the last time this list was scraped.
  presentOnList Boolean @default(true)
  /// added | skipped | failed -- outcome the last time this list tried to add it.
  status String
  /// Never add this film from this list (film-level override).
  excluded Boolean @default(false)

  firstSeenAt      DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  removedFromListAt DateTime?

  @@unique([listId, movieId])
  @@index([listId])
  @@index([movieId])
}

/// One user's watched-state cache for one film (DESIGN.md §7). Refreshed independently of any
/// list's own sync, on a global interval (Settings.watchedRefreshIntervalMin), once per user.
/// unwatchedOnly only needs presence (has this user watched it at all, ever). removeOnWatch needs
/// an actual date -- diary-sourced only; a watched-but-undiaried film can never trigger it, since
/// there's no reliable way to tell "just watched" from "watched years ago, only just noticed."
model WatchedFilm {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
  tmdbId Int

  /// The real diary-logged date, when Letterboxd has one. Null if the film is marked watched but
  /// was never diary-logged (Letterboxd allows a bare watched-checkbox with no diary entry).
  watchedAt DateTime?
  /// letterboxd_diary | letterboxd_aggregate | jellyfin
  source    String

  updatedAt DateTime @updatedAt

  @@unique([userId, tmdbId])
  @@index([userId])
}

/// The deletion approval queue (the keeper-rule's output, DESIGN.md §5-§6). A candidate is never
/// deleted directly — it's marked pending here for a human to approve or keep.
model DeletionRequest {
  id      Int   @id @default(autoincrement())
  movie   Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId Int

  /// left_list | watched | list_deleted | list_deactivated | manual_reopen (a human released a
  /// `kept` film back into the pipeline via dropKeepStatus, src/reconcile/index.ts)
  reason String

  /// The list whose sync caused this film to drop out of contention (informational; the
  /// keeper-rule itself only cares whether *any* enabled list still wants the film).
  triggeredByList   List? @relation(fields: [triggeredByListId], references: [id], onDelete: SetNull)
  triggeredByListId Int?

  /// pending | approved | kept
  status String @default("pending")

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([movieId])
  @@index([status])
}
